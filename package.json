{
  "name": "vulyo-javascript",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "pack:check": "node scripts/verify-package-contents.mjs",
    "runtime:check": "node scripts/verify-runtime-imports.mjs",
    "verify": "pnpm build && pnpm runtime:check && pnpm typecheck && pnpm test && pnpm pack:check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm verify && pnpm changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^20.19.43",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  }
}
