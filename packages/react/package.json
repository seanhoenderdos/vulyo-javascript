{
  "name": "@vulyo/react",
  "version": "0.1.0",
  "type": "module",
  "description": "Accessible, brandable authentication components and hooks for Vulyo React applications.",
  "license": "MIT",
  "files": ["dist", "README.md", "LICENSE"],
  "engines": { "node": ">=20.19 <25" },
  "repository": { "type": "git", "url": "git+https://github.com/seanhoenderdos/vulyo-javascript.git", "directory": "packages/react" },
  "bugs": { "url": "https://github.com/seanhoenderdos/vulyo-javascript/issues" },
  "homepage": "https://vulyo.com",
  "keywords": ["authentication", "react", "components", "vulyo"],
  "sideEffects": false,
  "publishConfig": { "access": "public", "provenance": true },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": { ".": { "types": "./dist/index.d.ts", "import": "./dist/index.js" } },
  "scripts": {
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@vulyo/core": "workspace:*",
    "lucide-react": "^0.562.0"
  },
  "peerDependencies": { "react": ">=19 <20", "react-dom": ">=19 <20" },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^29.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16",
    "vitest-axe": "^0.1.0"
  }
}
